# ── LLM provider (OpenAI-compatible) ─────────────────────────────────────────
# Dev: Groq (free, fast)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your_groq_api_key_here

# Demo day (July 21): swap to OpenAI — change these 3 lines only
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o
# LLM_API_KEY=your_openai_api_key_here

# ── CEFR Classifier ───────────────────────────────────────────────────────────
# Set to true to skip HuggingFace Space calls during offline development
USE_MOCK_CLASSIFIER=false

# Optional: override the HF Space used for classification
# CEFR_MODEL_REPO=yanou16/cefr-english-classifier

# ── HuggingFace (if private model) ───────────────────────────────────────────
# HF_TOKEN=hf_...
