# ── LLM provider (OpenAI) ─────────────────────────────────────────────────────
LLM_MODEL=gpt-5.6
LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL left empty → uses the default OpenAI endpoint
LLM_BASE_URL=

# ── CEFR Classifier ───────────────────────────────────────────────────────────
# Set to true to skip HuggingFace Space calls during offline development
USE_MOCK_CLASSIFIER=false

# Optional: override the HF Space used for classification
# CEFR_MODEL_REPO=yanou16/cefr-english-classifier

# ── HuggingFace (if private model) ───────────────────────────────────────────
# HF_TOKEN=hf_...
